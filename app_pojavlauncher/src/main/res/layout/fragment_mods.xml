<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/mods_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/mods_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mods"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:alpha="0"
            android:translationY="20dp"/>

        <TextView
            android:id="@+id/mods_detected_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Detecting version…"
            android:textColor="#888888"
            android:textSize="12sp"
            android:alpha="0"/>
    </LinearLayout>

    <!-- Search bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <EditText
            android:id="@+id/mods_search"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/mods_search_bg"
            android:hint="Search mods…"
            android:hintTextColor="#555555"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:alpha="0"
            android:translationY="10dp"/>
    </FrameLayout>

    <!-- Filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:id="@+id/mods_filter_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="All"
                android:textColor="#000000"
                android:background="@drawable/chip_active_bg"
                android:paddingHorizontal="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_fabric"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Fabric"
                android:textColor="#FFFFFF"
                android:background="@drawable/chip_inactive_bg"
                android:paddingHorizontal="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_forge"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Forge"
                android:textColor="#FFFFFF"
                android:background="@drawable/chip_inactive_bg"
                android:paddingHorizontal="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_quilt"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Quilt"
                android:textColor="#FFFFFF"
                android:background="@drawable/chip_inactive_bg"
                android:paddingHorizontal="14dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Mod list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/mods_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"/>

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/mods_loading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/mods_progress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#FFFFFF"/>

        <TextView
            android:id="@+id/mods_loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Loading mods…"
            android:textColor="#888888"
            android:textSize="13sp"/>
    </LinearLayout>

</LinearLayout>
