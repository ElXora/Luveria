<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/background_card"
    android:padding="14dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Mod icon placeholder -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/mod_icon_bg">
            <TextView
                android:id="@+id/mod_icon_letter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="M"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- Title + author -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/mod_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mod Name"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/mod_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="by Author"
                android:textColor="#666666"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Install button -->
        <Button
            android:id="@+id/mod_install_btn"
            android:layout_width="80dp"
            android:layout_height="34dp"
            android:text="Install"
            android:textColor="#000000"
            android:background="@drawable/btn_install_bg"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:padding="0dp"/>
    </LinearLayout>

    <!-- Description -->
    <TextView
        android:id="@+id/mod_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Mod description here."
        android:textColor="#777777"
        android:textSize="11sp"
        android:maxLines="2"
        android:ellipsize="end"/>

    <!-- Version badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/mod_version_badge"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="1.20.1"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:background="@drawable/chip_inactive_bg"
            android:paddingHorizontal="8dp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/mod_loader_badge"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="Fabric"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:background="@drawable/chip_inactive_bg"
            android:paddingHorizontal="8dp"
            android:gravity="center"
            android:layout_marginStart="6dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/mod_downloads"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↓ 12k"
            android:textColor="#555555"
            android:textSize="10sp"/>
    </LinearLayout>
</LinearLayout>
