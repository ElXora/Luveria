<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:background="#000000">

    <!-- Row title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_setting_video"
            android:tint="#FFFFFF"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Graphics Preset"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Controls particles, clouds, render distance &amp; FPS"
                android:textColor="#666666"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- The 3-segment bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@drawable/preset_bar_bg"
        android:padding="4dp">

        <!-- HIGH -->
        <LinearLayout
            android:id="@+id/preset_btn_high"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/preset_btn_inactive_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All effects on"
                android:textColor="#555555"
                android:textSize="9sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- MID -->
        <LinearLayout
            android:id="@+id/preset_btn_mid"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/preset_btn_inactive_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MID"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Balanced · default"
                android:textColor="#555555"
                android:textSize="9sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- LOW -->
        <LinearLayout
            android:id="@+id/preset_btn_low"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/preset_btn_inactive_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOW"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max FPS + mods"
                android:textColor="#555555"
                android:textSize="9sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Detail cards shown below the bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <!-- HIGH detail -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/background_card"
            android:padding="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· All particles" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· Clouds ON" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· RD 12 chunks" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· Fancy graphics" android:textColor="#555555" android:textSize="9sp"/>
        </LinearLayout>

        <View android:layout_width="4dp" android:layout_height="1dp"/>

        <!-- MID detail -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/background_card"
            android:padding="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· Less particles" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· Clouds OFF" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· RD 8 chunks" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· Fast graphics" android:textColor="#555555" android:textSize="9sp"/>
        </LinearLayout>

        <View android:layout_width="4dp" android:layout_height="1dp"/>

        <!-- LOW detail -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/background_card"
            android:padding="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· No particles" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· Clouds OFF" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· RD 6 chunks" android:textColor="#555555" android:textSize="9sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="· Auto-perf mods" android:textColor="#AAAAAA" android:textSize="9sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
