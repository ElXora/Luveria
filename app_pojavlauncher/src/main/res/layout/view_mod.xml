<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/background_card"
    android:padding="14dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/mod_thumbnail"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/mod_icon_bg"
            android:scaleType="centerCrop"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/mod_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/mod_author_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#666666"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/mod_install_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/btn_install_bg"
            android:src="@android:drawable/ic_menu_add"
            android:padding="8dp"
            android:scaleType="fitCenter"/>
    </LinearLayout>

    <TextView
        android:id="@+id/mod_description_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#777777"
        android:textSize="11sp"
        android:maxLines="2"
        android:ellipsize="end"/>
</LinearLayout>
